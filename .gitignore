src/rag/documents/*.pdf

# ── Planning & internal docs (not for public repo) ───────
# All planning, status, and deployment notes live in DEV_NOTES/
DEV_NOTES/

# ── OS noise ────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
