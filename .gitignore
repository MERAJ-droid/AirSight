__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ────────────────────────────────
.venv/
venv/
env/
ENV/
linux_env/

# ── Jupyter ─────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data (never commit raw data or processed splits) ───
data/raw/
data/train.csv
data/val.csv
data/test.csv

# ── Artifacts (models, scalers — large binaries) ────────
artifacts/
logs/

# ── Kaggle credentials (specific file, not all JSON) ────
kaggle.json

# ── Environment / secrets ────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# ── Output / scratch images ─────────────────────────────
output.png
output.jpg

# ── RAG source PDFs (vectorstore already built + hosted on HF Hub) ───────────
